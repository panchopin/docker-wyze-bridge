#!/bin/sh

if [ -f /app/.env ]; then
    set -a
    # shellcheck disable=SC1091
    . /app/.env
    set +a
fi

if [ "$BUILD" = "dev" ]; then
    echo "[RUN] Development build enabled; raw add-on options are not printed."
fi

start_whep_proxy() {
    if command -v whep_proxy >/dev/null 2>&1; then
        whep_port="${WHEP_PROXY_PORT:-8080}"
        whep_port_is_open() {
            python3 - "$1" <<'PY'
import socket
import sys

port = int(sys.argv[1])
sock = socket.socket()
sock.settimeout(1)
try:
    sock.connect(("127.0.0.1", port))
except OSError:
    raise SystemExit(1)
finally:
    sock.close()
PY
        }

        if whep_port_is_open "$whep_port"; then
            echo "[WHEP_PROXY] Existing listener detected on 127.0.0.1:${whep_port}; not starting a duplicate." >&2
            return
        fi
        if command -v ps >/dev/null 2>&1; then
            for pid in $(ps | awk '/[s]h -c/ && /whep_proxy/ {print $1}'); do
                kill "$pid" 2>/dev/null || true
            done
        fi
        if command -v pkill >/dev/null 2>&1; then
            pkill -f '[w]hep_proxy >>/tmp/whep_proxy.log' 2>/dev/null || true
            pkill -x whep_proxy 2>/dev/null || true
        elif command -v pidof >/dev/null 2>&1; then
            # shellcheck disable=SC2046
            kill $(pidof whep_proxy) 2>/dev/null || true
        fi
        sleep 1
        if whep_port_is_open "$whep_port"; then
            echo "[WHEP_PROXY] Reusing listener on 127.0.0.1:${whep_port} after cleanup." >&2
            return
        fi
        nohup sh -c '
            while :; do
                whep_proxy >>/tmp/whep_proxy.log 2>&1
                status=$?
                printf "%s whep_proxy exited with status %s\n" "$(date -Iseconds)" "$status" >>/tmp/whep_proxy.log
                sleep 2
            done
        ' </dev/null >/dev/null 2>&1 &
    fi
}

start_whep_proxy

. /app/go2rtc_sidecar.sh
start_go2rtc_sidecar

export PYTHONPATH="/app${PYTHONPATH:+:$PYTHONPATH}"

exec flask run --host=0.0.0.0 --port="${WB_APP_PORT:-5000}"
